# Ignorados de Docker para el frontend
# Evita copiar carpetas masivas de dependencias del host al contexto de build de la imagen.
node_modules/
dist/
dist-ssr/
build/

# Variables de entorno y secretos (se inyectan en runtime, no en build)
.env
.env.*
!.env.example
*.local

# Configuración de editores e IDEs
.vscode/
.idea/

# Historial de Git (innecesario dentro del contenedor)
.git
.gitignore

# Sistema operativo
.DS_Store
