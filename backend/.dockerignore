# Ignorados de Docker para el backend
# Evita copiar archivos cacheados e innecesarios al contexto de build del contenedor Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Entornos virtuales locales (no se deben copiar al contenedor)
env/
venv/
.venv/

# Variables de entorno y secretos (se inyectan en runtime, no en build)
.env
.env.*
!.env.example

# Historial de Git (innecesario dentro del contenedor)
.git
.gitignore

# Configuración de editores y sistema operativo
.vscode/
.idea/
.DS_Store
