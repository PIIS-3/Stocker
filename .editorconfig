# EditorConfig – https://editorconfig.org
# Garantiza un estilo de código consistente en todos los editores e IDEs del equipo.
# Cada miembro del equipo debe tener la extensión EditorConfig instalada en su editor.

root = true

# ── Valores por defecto (aplica a todos los archivos) ────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ── Python (4 espacios según PEP 8) ─────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 100

# ── Markdown (no recortar espacios finales — son saltos de línea) ────
[*.md]
trim_trailing_whitespace = false

# ── Makefiles (requieren tabulaciones obligatoriamente) ──────────────
[Makefile]
indent_style = tab
